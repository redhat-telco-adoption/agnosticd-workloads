apiVersion: apps/v1
kind: Deployment
metadata:
  name: worker
  namespace: incident-simulator
  labels:
    app: worker
    app.kubernetes.io/name: worker
    app.kubernetes.io/component: worker
    app.kubernetes.io/part-of: incident-simulator
    demo.redhat.com/name: coo-incident-detection
    demo.redhat.com/created-by: agnosticd
spec:
  replicas: 1
  selector:
    matchLabels:
      app: worker
  template:
    metadata:
      labels:
        app: worker
        app.kubernetes.io/name: worker
        app.kubernetes.io/component: worker
        app.kubernetes.io/part-of: incident-simulator
        demo.redhat.com/name: coo-incident-detection
    spec:
      containers:
      - name: worker
        image: "quay.io/redhat-telco-adoption/incident-simulator-worker:{{ ocp4_workload_coo_incident_detection_app_image_tag }}"
        imagePullPolicy: Always
        ports:
        - containerPort: 8081
          name: http
          protocol: TCP
        env:
        - name: OTEL_EXPORTER_OTLP_ENDPOINT
          value: "otel-collector.tempo.svc.cluster.local:4317"
        - name: OTEL_SERVICE_NAME
          value: "worker"
        - name: OTEL_RESOURCE_ATTRIBUTES
          value: "service.namespace=incident-simulator,service.version=1.0.0"
        resources:
          requests:
            cpu: 100m
            memory: 128Mi
          limits:
            cpu: "2"
            memory: 512Mi
        livenessProbe:
          httpGet:
            path: /health
            port: 8081
          initialDelaySeconds: 5
          periodSeconds: 10
          failureThreshold: 5
        readinessProbe:
          httpGet:
            path: /ready
            port: 8081
          initialDelaySeconds: 5
          periodSeconds: 5
        volumeMounts:
        - name: tmp
          mountPath: /tmp
      volumes:
      - name: tmp
        emptyDir:
          sizeLimit: 1Gi

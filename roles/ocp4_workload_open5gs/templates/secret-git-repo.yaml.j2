---
# ArgoCD repository credential for the private git repo.
# The url must match exactly what is set in the Application sourceRepos.
apiVersion: v1
kind: Secret
metadata:
  name: repo-openshift-5g
  namespace: "{{ ocp4_workload_open5gs_argocd_namespace }}"
  labels:
    argocd.argoproj.io/secret-type: repository
stringData:
  type: git
  url: "{{ ocp4_workload_open5gs_git_repo }}"
  username: "{{ ocp4_workload_open5gs_git_username }}"
  password: "{{ ocp4_workload_open5gs_git_token }}"
